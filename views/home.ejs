<%- include('partials/header') %>

<% if (body.message) { %>
  <div class="ss-alert ss-alert-success mb-3">
    <i class="fas fa-check-circle me-1"></i> <%= body.message %>
  </div>
<% } %>
<% if (body.error) { %>
  <div class="ss-alert ss-alert-danger mb-3">
    <i class="fas fa-exclamation-circle me-1"></i> <%= body.error %>
  </div>
<% } %>

<!-- Locating spinner -->
<div id="locating-state" class="locate-state">
  <div class="locate-spinner"></div>
  <p class="locate-title">Locating you&hellip;</p>
  <p class="locate-hint">Allow location access when prompted</p>
</div>

<p class="gps-error mt-3" id="gpsError"></p>

<!-- Hidden: GPS coordinates -->
<div class="d-none" id="coord-x"></div>
<div class="d-none" id="coord-y"></div>

<!-- Manual search (always visible once page loads) -->
<div class="search-wrapper mt-3" id="search-section">
  <i class="fas fa-search search-icon-prefix"></i>
  <input autocomplete="off" type="text" onkeyup="find(this)" class="search-field"
    id="search-field" placeholder="Search community or street&hellip;">
  <div class="search-results" id="resultList"></div>
</div>

<!-- Search result display (populated by locate.js / search.js) -->
<div id="defaultInfo" class="mt-3">
  <div id="communityDescription"></div>
  <div id="searchedCode"></div>
</div>

<!-- Re-locate button (shown after locate completes) -->
<div class="d-none mt-3 text-center" id="locate-relocate">
  <button type="button" class="btn btn-sm btn-outline-secondary" onclick="reLocate()">
    <i class="fas fa-sync me-1"></i> Re-locate
  </button>
</div>

<!-- Admin include form (hidden, submitted when admin confirms) -->
<form class="d-none" id="geoCodeForm" action="<%= body.domain %>/adminInclude" method="post">
  <textarea name="locationJSONString" id="locationJSONString"></textarea>
</form>

<!-- Admin include trigger (shown for unregistered communities) -->
<div class="d-none" id="adminInclude">
  <div class="unregistered-banner">
    <p class="unregistered-title"><i class="fas fa-map-marker-alt me-1"></i> Unregistered Community</p>
    <p class="unregistered-text">This street isn't in the database yet. Admins can add it.</p>
    <button type="button" class="btn-accent" onclick="focusOnAdminPass()"
      data-bs-toggle="modal" data-bs-target="#adminPassModal">
      <i class="fas fa-plus"></i> Include Community
    </button>
  </div>
</div>

<!-- Admin password modal -->
<div class="modal fade" id="adminPassModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title fw-bold">Admin Access Required</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="accessForm">
        <div class="modal-body">
          <p class="text-danger small mb-2" id="error-message"></p>
          <input type="password" class="form-control" placeholder="Admin password" id="adminPass" autocomplete="current-password">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-sm btn-warning fw-semibold">Continue</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
